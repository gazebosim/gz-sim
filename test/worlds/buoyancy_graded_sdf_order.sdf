<?xml version="1.0" ?>
<!--
  Test world for SDF parsing order bug:
  <enable> appears before <graded_buoyancy> in the plugin block.
  We use default_density=500 so if parsing fails the unparsed default
  of 1000 produces detectably different buoyancy on the test model.
-->
<sdf version="1.6">
  <world name="buoyancy">

    <physics name="1ms" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>0</real_time_factor>
    </physics>
    <plugin
      filename="gz-sim-physics-system"
      name="gz::sim::systems::Physics">
    </plugin>
    <plugin
      filename="gz-sim-buoyancy-system"
      name="gz::sim::systems::Buoyancy">
      <!-- enable appears BEFORE graded_buoyancy to test SDF parsing order -->
      <enable>parse_test_box</enable>
      <graded_buoyancy>
        <default_density>500</default_density>
        <density_change>
          <above_depth>0</above_depth>
          <density>1</density>
        </density_change>
      </graded_buoyancy>
    </plugin>

    <!-- Box at z=-5, fully submerged.
         Volume = 1 m^3, mass = 500 kg -> density = 500 kg/m^3.
         With correct parsing (default_density=500): neutrally buoyant, stays.
         With broken parsing (default_density=1000): too much buoyancy, floats up. -->
    <model name='parse_test_box'>
      <pose>0 0 -5 0 0 0</pose>
      <link name='body'>
        <inertial>
          <mass>500</mass>
          <inertia>
            <ixx>83.33</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>83.33</iyy>
            <iyz>0</iyz>
            <izz>83.33</izz>
          </inertia>
        </inertial>
        <collision name='body_collision'>
          <geometry>
            <box>
              <size>1 1 1</size>
            </box>
          </geometry>
        </collision>
        <visual name='body_visual'>
          <geometry>
            <box>
              <size>1 1 1</size>
            </box>
          </geometry>
        </visual>
      </link>
    </model>

  </world>
</sdf>
