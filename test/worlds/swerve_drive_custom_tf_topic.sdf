      <link name='back_right_wheel_link'>
        <pose>-0.62 -0.22 -0.29 -1.5707 0 0</pose>
        <inertial>
          <mass>0.35</mass>
          <inertia>
            <ixx>0.00126</ixx>
            <ixy>0</ixy>
            <ixz>0</ixz>
            <iyy>0.00126</iyy>
            <iyz>0</iyz>
            <izz>0.00252</izz>
          </inertia>
        </inertial>
        <visual name='visual'>
          <geometry>
            <cylinder>
              <length>0.05</length>
              <radius>0.12</radius>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.2 0.2 0.2 1</ambient>
            <diffuse>0.2 0.2 0.2 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
        </visual>
        <collision name='collision'>
          <geometry>
            <cylinder>
              <length>0.05</length>
              <radius>0.12</radius>
            </cylinder>
          </geometry>
          <surface>
            <friction>
              <ode>
                <mu>0.5</mu>
                <mu2>1.0</mu2>
                <fdir1>1 0 0</fdir1>
              </ode>
              <bullet>
                <friction>0.5</friction>
                <friction2>1.0</friction2>
                <rolling_friction>0.1</rolling_friction>
              </bullet>
            </friction>
          </surface>
        </collision>
      </link>

      <link name="front_left_steering_link">
        <pose>0.22 0.22 -0.16 0 0 0</pose>
        <inertial>
          <mass>0.08</mass>
          <inertia>
            <ixx>0.000135</ixx>
            <iyy>0.000135</iyy>
            <izz>0.000218</izz>
          </inertia>
        </inertial>
        <visual name="steering_link_visual">
          <pose>0 0 0 0 0 0</pose>
          <geometry>
            <cylinder>
              <length>0.018</length>
              <radius>0.13</radius>
            </cylinder>
          </geometry>
          <material>
            <ambient>1 1 1</ambient>
            <diffuse>1 1 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="front_right_steering_link">
        <pose>0.22 -0.22 -0.16 0 0 0</pose>
        <inertial>
          <mass>0.08</mass>
          <inertia>
            <ixx>0.000135</ixx>
            <iyy>0.000135</iyy>
            <izz>0.000218</izz>
          </inertia>
        </inertial>
        <visual name="steering_link_visual">
          <pose>0 0 0 0 0 0</pose>
          <geometry>
            <cylinder>
              <length>0.018</length>
              <radius>0.13</radius>
            </cylinder>
          </geometry>
          <material>
            <ambient>1 1 1</ambient>
            <diffuse>1 1 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="back_left_steering_link">
        <pose>-0.62 0.22 -0.16 0 0 0</pose>
        <inertial>
          <mass>0.08</mass>
          <inertia>
            <ixx>0.000135</ixx>
            <iyy>0.000135</iyy>
            <izz>0.000218</izz>
          </inertia>
        </inertial>
        <visual name="steering_link_visual">
          <pose>0 0 0 0 0 0</pose>
          <geometry>
            <cylinder>
              <length>0.018</length>
              <radius>0.13</radius>
            </cylinder>
          </geometry>
          <material>
            <ambient>1 1 1</ambient>
            <diffuse>1 1 1</diffuse>
          </material>
        </visual>
      </link>

      <link name="back_right_steering_link">
        <pose>-0.62 -0.22 -0.16 0 0 0</pose>
        <inertial>
          <mass>0.08</mass>
          <inertia>
            <ixx>0.000135</ixx>
            <iyy>0.000135</iyy>
            <izz>0.000218</izz>
          </inertia>
        </inertial>
        <visual name="steering_link_visual">
          <pose>0 0 0 0 0 0</pose>
          <geometry>
            <cylinder>
              <length>0.018</length>
              <radius>0.13</radius>
            </cylinder>
          </geometry>
          <material>
            <ambient>1 1 1</ambient>
            <diffuse>1 1 1</diffuse>
          </material>
        </visual>
      </link>

      <joint name="front_left_steering_joint" type="revolute">
        <parent>chassis</parent>
        <child>front_left_steering_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
            <velocity>20.0</velocity>
            <effort>25</effort>
          </limit>
          <use_parent_model_frame>1</use_parent_model_frame>
        </axis>
      </joint>

      <joint name="front_right_steering_joint" type="revolute">
        <parent>chassis</parent>
        <child>front_right_steering_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
            <velocity>20.0</velocity>
            <effort>25</effort>
          </limit>
          <use_parent_model_frame>1</use_parent_model_frame>
        </axis>
      </joint>

      <joint name="back_left_steering_joint" type="revolute">
        <parent>chassis</parent>
        <child>back_left_steering_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
            <velocity>20.0</velocity>
            <effort>25</effort>
          </limit>
          <use_parent_model_frame>1</use_parent_model_frame>
        </axis>
      </joint>

      <joint name="back_right_steering_joint" type="revolute">
        <parent>chassis</parent>
        <child>back_right_steering_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
            <velocity>20.0</velocity>
            <effort>25</effort>
          </limit>
          <use_parent_model_frame>1</use_parent_model_frame>
        </axis>
      </joint>

      <joint name='front_left_wheel_joint' type='revolute'>
        <parent>front_left_steering_link</parent>
        <child>front_left_wheel_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <joint name='front_right_wheel_joint' type='revolute'>
        <parent>front_right_steering_link</parent>
        <child>front_right_wheel_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <joint name='back_left_wheel_joint' type='revolute'>
        <parent>back_left_steering_link</parent>
        <child>back_left_wheel_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <joint name='back_right_wheel_joint' type='revolute'>
        <parent>back_right_steering_link</parent>
        <child>back_right_wheel_link</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-1.79769e+308</lower>
            <upper>1.79769e+308</upper>
          </limit>
        </axis>
      </joint>

      <plugin
        filename="gz-sim-swerve-drive-system"
        name="gz::sim::systems::SwerveDrive">
        <front_left_wheel_joint>front_left_wheel_joint</front_left_wheel_joint>
        <front_right_wheel_joint>front_right_wheel_joint</front_right_wheel_joint>
        <back_left_wheel_joint>back_left_wheel_joint</back_left_wheel_joint>
        <back_right_wheel_joint>back_right_wheel_joint</back_right_wheel_joint>
        <front_left_steering_joint>front_left_steering_joint</front_left_steering_joint>
        <front_right_steering_joint>front_right_steering_joint</front_right_steering_joint>
        <back_left_steering_joint>back_left_steering_joint</back_left_steering_joint>
        <back_right_steering_joint>back_right_steering_joint</back_right_steering_joint>
        <wheel_separation>0.44</wheel_separation>
        <wheelbase>0.84</wheelbase>
        <wheel_radius>0.12</wheel_radius>
        <limit_speed_on_steering_err>true</limit_speed_on_steering_err>
        <steering_err_threshold>0.314149</steering_err_threshold>
        <speed_limit_power>2</speed_limit_power>
        <min_linear_acceleration>-1.0</min_linear_acceleration>
        <max_linear_acceleration>1.0</max_linear_acceleration>
        <min_angular_acceleration>-2.0</min_angular_acceleration>
        <max_angular_acceleration>2.0</max_angular_acceleration>
        <min_linear_velocity>-0.5</min_linear_velocity>
        <max_linear_velocity>0.5</max_linear_velocity>
        <min_angular_velocity>-1.0</min_angular_velocity>
        <max_angular_velocity>1.0</max_angular_velocity>
        <steer_p_gain>2</steer_p_gain>
        <topic>/model/foo/cmdvel</topic>
        <odom_topic>/model/bar/odom</odom_topic>
        <tf_topic>tf_foo</tf_topic>
      </plugin>

    </model>

  </world>
</sdf>
